{
    "manifest_version": 2,
    "name": "Rabbit-Hole Blocker",
    "version": "1.0.0",
    "description": "Eliminates algorithmic distractions on YouTube and Reddit by hiding feeds, recommendations, and comments.",
    "permissions": [
        "activeTab",
        "storage",
        "alarms",
        "*://*.youtube.com/*",
        "*://*.reddit.com/*"
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "rabbit-hole-blocker@extension",
            "strict_min_version": "109.0"
        }
    },
    "background": {
        "scripts": [
            "background.js"
        ]
    },
    "browser_action": {
        "default_popup": "popup/popup.html",
        "default_title": "Rabbit-Hole Blocker",
        "default_icon": {
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "128": "icons/icon128.png"
    }
}