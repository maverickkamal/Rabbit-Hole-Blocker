{
  "manifest_version": 3,
  "name": "Rabbit-Hole Blocker",
  "version": "1.0.0",
  "description": "Eliminates algorithmic distractions on YouTube and Reddit by hiding feeds, recommendations, and comments.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.reddit.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Rabbit-Hole Blocker"
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}